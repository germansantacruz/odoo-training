<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_library_book_list" model="ir.ui.view">
        <field name="name">library.book.list</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <list string="Libros" delete="0">
                <field name="name"/>     
                <field name="fecha_publicacion" />
                <field name="isbn"/>
                <field name="price"/>
                <field name="state" widget="badge" decoration-info="state == 'available'" decoration-warning="state == 'borrowed'"/>           
            </list>
        </field>
    </record>

    <record id="view_library_book_form" model="ir.ui.view">
        <field name="name">library.book.form</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <form string="Libro" delete="0">
                <header>                        
                    <field name="state" widget="statusbar" options="{'clickable': '1'}"/>             
                </header>
                <sheet>                   
                    <div class="oe_title">                        
                        <h1>
                            <field name="name" placeholder="Ej: Dominando Odoo 18"/>
                        </h1>
                    </div>
                    <group>                       
                        <group string="Información Comercial">
                            <field name="fecha_publicacion"/>
                            <field name="price" decoration-info="price >= 100" readonly="state == 'borrowed'"/>                                           
                            <field name="active" widget="boolean_toggle"/> 
                        </group>                        
                        <group string="Datos Técnicos">
                            <field name="isbn"/>
                            <field name="publisher_url" widget="url" placeholder="e.g. https://www.lapapelera.com"/>
                            <field name="cover_image" widget="image" nolabel="1"
                                options="{'preview_image': 'cover_image'}" class="cover-image"/>
                        </group>
                    </group> 
                    <notebook>
                        <page string="Resumen">
                            <field name="descripcion" placeholder="Escribe una breve reseña del libro..."/>
                        </page>
                    </notebook>                   
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_library_book" model="ir.actions.act_window">
        <field name="name">Libros</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">library.book</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea tu primer libro
            </p>
        </field>
    </record>
</odoo>