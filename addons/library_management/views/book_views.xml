<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_library_book_list" model="ir.ui.view">
        <field name="name">library.book.list</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <list string="Libros" delete="0">
                <field name="name"/>     
                <field name="fecha_publicacion" />
                <field name="isbn"/>
                <field name="price"/>
                <field name="state" widget="badge" decoration-info="state == 'available'" decoration-warning="state == 'borrowed'"/>           
            </list>
        </field>
    </record>

    <record id="view_library_book_form" model="ir.ui.view">
        <field name="name">library.book.form</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <form string="Libro" delete="0">
                <header>
                    <button name="action_set_available" string="Validar Libro" 
                        type="object" class="btn-primary" invisible="state != 'draft'"/>                        
                    <field name="state" widget="statusbar" options="{'clickable': '1'}"/>             
                </header>
                <sheet> 
                    <div class="oe_button_box" name="button_box">
                        <button name="action_archive" type="object" class="oe_stat_button" 
                                icon="fa-archive" invisible="not active">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Archivar</span>
                            </div>
                        </button>
                        <button name="action_unarchive" type="object" class="oe_stat_button" 
                                icon="fa-check" invisible="active">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Activar</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">                        
                        <h1>
                            <field name="name" placeholder="Ej: Dominando Odoo 18"/>
                        </h1>
                    </div>
                    <group>                       
                        <group string="Información Comercial">
                            <field name="fecha_publicacion"/>
                            <field name="price" decoration-info="price >= 100" readonly="state == 'borrowed'"/>                                           
                            <field name="active" widget="boolean_toggle"/> 
                        </group>                        
                        <group string="Datos Técnicos">
                            <field name="isbn"/>
                            <field name="publisher_url" widget="url" placeholder="e.g. https://www.lapapelera.com"/>
                            <field name="cover_image" widget="image" nolabel="1"
                                options="{'preview_image': 'cover_image'}" class="cover-image"/>
                        </group>
                    </group> 
                    <notebook>
                        <page string="Resumen">
                            <field name="descripcion" placeholder="Escribe una breve reseña del libro..."/>
                        </page>
                        <page string="Ejemplares Físicos" name="copies">
                            <field name="copy_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="format_id"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                    </notebook>                   
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_library_book_kanban" model="ir.ui.view">
        <field name="name">library.book.kanban</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_mobile" sample="1" create="0">
                <field name="name"/>                
                <field name="cover_image"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click o_kanban_record_has_image_fill">
                            <div class="o_kanban_image_fill_left d-none d-md-block" 
                                t-attf-style="background-image:url('#{kanban_image('library.book', 'cover_image', record.id.raw_value)}')"/>
                            
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>                               
                                <div class="o_kanban_record_bottom">                                    
                                    <div class="oe_kanban_bottom_right">
                                        <field name="state" widget="label_selection"
                                            options="{'classes': {'draft': 'info', 'available': 'success', 'borrowed': 'warning', 'lost': 'danger'}}"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_library_book" model="ir.actions.act_window">
        <field name="name">Libros</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">library.book</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea tu primer libro
            </p>
        </field>
    </record>
</odoo>